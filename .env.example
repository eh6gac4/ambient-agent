# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (credentials.json からコピー)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Notion
NOTION_TOKEN=secret_...
NOTION_TASKS_DB_ID=        # タスクを書き込む DB の ID

# Telegram
TELEGRAM_BOT_TOKEN=        # BotFather から取得
TELEGRAM_CHAT_ID=          # @userinfobot などで確認

# 設定
GMAIL_CHECK_INTERVAL_MINUTES=15
GMAIL_TASK_LABEL=タスク登録済み  # タスク登録したメールに付与するラベル名
DAILY_BRIEFING_HOUR=8      # 毎朝何時にブリーフィングするか（24時間制）
